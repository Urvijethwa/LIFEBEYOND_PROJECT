<% layout("layouts/boilerplate") %>

<div class="listing-form">
    <h2>Book a Viewing</h2>

    <form action="/listings/<%= listing._id %>/enquiry" method="POST">

        <div class="form-group">
            <label for="viewingDate">Preferred Viewing Date</label>
            <input type="date" name="viewingDate" id="viewingDate" required>
        </div>

        <div class="form-group">
            <label for="viewingTime">Preferred Viewing Time</label>
            <input type="time" name="viewingTime" id="viewingTime" required>
        </div>

        <div class="form-group">
            <label for="message">Message to Host</label>
            <textarea 
                name="message" 
                id="message" 
                placeholder="Example: Hi, I would like to view this property on my selected date and time."
                required
            ></textarea>
        </div>

        <button class="btn">Send Viewing Request</button>
    </form>
</div>