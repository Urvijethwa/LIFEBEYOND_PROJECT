<% layout("layouts/boilerplate") %>

<div class="page-header">
    <div>
        <h1>My Bookings</h1>
        <p class="location">View and manage your booking requests.</p>
    </div>
</div>

<% if(bookings.length === 0) { %>
    <div class="empty-state">
        <p>You have not made any bookings yet.</p>
    </div>
<% } else { %>
    <div class="card-container">
        <% for(let booking of bookings) { %>
            <div class="card">
                <img 
                    src="<%= booking.listing.image %>" 
                    alt="<%= booking.listing.title %>" 
                    class="card-img"
                >

                <div class="card-body">
                    <h3><%= booking.listing.title %></h3>
                    <p class="location"><%= booking.listing.location %>, <%= booking.listing.country %></p>
                    <p><strong>Check-in:</strong> <%= booking.checkIn.toDateString() %></p>
                    <p><strong>Check-out:</strong> <%= booking.checkOut.toDateString() %></p>
                    <p><strong>Guests:</strong> <%= booking.guests %></p>
                    <p class="price">Estimated Total: £<%= booking.totalPrice %></p>
                    <p><strong>Status:</strong> <%= booking.status %></p>

                    <% if(booking.status !== "cancelled") { %>
                        <form action="/bookings/<%= booking._id %>/cancel" method="POST">
                            <button class="btn delete-btn">Cancel Booking</button>
                        </form>
                    <% } %>
                </div>
            </div>
        <% } %>
    </div>
<% } %>