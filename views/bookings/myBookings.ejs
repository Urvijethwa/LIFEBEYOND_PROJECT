<% layout("layouts/boilerplate") %>
<!-- Uses main layout (navbar, footer, styles) -->

<div class="page-header">
    <div>
        <h1>My Bookings</h1>
        <!-- Page title -->

        <p class="location">View and manage your booking requests.</p>
        <!-- Small description -->
    </div>
</div>

<!-- IF user has no bookings -->
<% if(bookings.length === 0) { %>
    <div class="empty-state">
        <p>You have not made any bookings yet.</p>
    </div>

<!-- ELSE show bookings -->
<% } else { %>
    <div class="card-container">

        <!-- LOOP through all bookings -->
        <% for(let booking of bookings) { %>
            <div class="card">

                <!-- Listing Image (with fallback if image fails) -->
                <% if(booking.listing && booking.listing.image) { %>
                    <img 
                        src="<%= booking.listing?.image || 'https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?w=1000' %>" 
                        alt="listing image"
                        class="card-img"
                        onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?w=1000';"
                    />
                <% } %>

                <div class="card-body">

                    <!-- Listing Title -->
                    <h3>
                        <%= booking.listing ? booking.listing.title : "Listing unavailable" %>
                    </h3>

                    <!-- Location -->
                    <% if(booking.listing) { %>
                        <p class="location">
                            <%= booking.listing.location %>, <%= booking.listing.country %>
                        </p>
                    <% } %>

                    <!-- Booking Status -->
                    <p><strong>Status:</strong> <%= booking.status %></p>

                    <!-- Enquiry message (if exists) -->
                    <% if(booking.message) { %>
                        <p><strong>Message:</strong> <%= booking.message %></p>
                    <% } %>

                    <!-- If it's a FULL booking (not just enquiry) -->
                    <% if(booking.checkIn && booking.checkOut) { %>

                        <!-- Dates -->
                        <p><strong>Check-in:</strong> <%= booking.checkIn.toDateString() %></p>
                        <p><strong>Check-out:</strong> <%= booking.checkOut.toDateString() %></p>

                        <!-- Guests -->
                        <p><strong>Guests:</strong> <%= booking.guests %></p>

                        <!-- Price -->
                        <p class="price">
                            Estimated Total: £<%= booking.totalPrice %>
                        </p>

                    <% } else { %>

                        <!-- If only enquiry -->
                        <p class="location">
                            This is an enquiry only. No booking dates selected.
                        </p>

                    <% } %>

                    <!-- ========================= -->
                    <!-- PAYMENT FEATURE -->
                    <!-- ========================= -->

                    <% if(booking.status === "approved" && booking.checkIn && booking.checkOut) { %>
                        <a href="/bookings/<%= booking._id %>/payment" class="btn">
                            Pay Now
                        </a>
                    <% } %>

                    <!-- ========================= -->
                    <!-- SUCCESS + REVIEW FEATURE -->
                    <!-- ========================= -->

                    <% if(booking.status === "paid" && booking.listing) { %>

                        <div class="success-message booking-paid-box">
                            Payment completed. Booking confirmed.
                        </div>

                        <!-- Redirect to review section -->
                        <a href="/listings/<%= booking.listing._id %>#reviews" class="btn">
                            Leave Review
                        </a>

                    <% } %>

                    <!-- ========================= -->
                    <!-- CANCEL BOOKING FEATURE -->
                    <!-- ========================= -->

                    <% if(booking.status !== "cancelled" && booking.status !== "paid") { %>
                        <form action="/bookings/<%= booking._id %>/cancel" method="POST">
                            <button class="btn delete-btn">Cancel</button>
                        </form>
                    <% } %>

                </div>
            </div>
        <% } %>
    </div>
<% } %>