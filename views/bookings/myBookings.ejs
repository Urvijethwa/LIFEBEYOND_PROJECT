<% layout("layouts/boilerplate") %>

<div class="page-header">
    <div>
        <h1>My Bookings</h1>
        <p class="location">View and manage your accommodation bookings.</p>
    </div>
</div>

<% if(bookings.length === 0) { %>

    <div class="empty-state">
        <p>You have not made any bookings yet.</p>
        <a href="/listings" class="btn" style="margin-top: 18px;">Explore Listings</a>
    </div>

<% } else { %>

<div class="bookings-grid">

    <% bookings.forEach(booking => { %>

        <div class="booking-card-modern">

            <img 
                src="<%= booking.listing.image %>" 
                alt="<%= booking.listing.title %>"
                class="booking-modern-img"
            >

            <div class="booking-modern-content">

                <h3><%= booking.listing.title %></h3>

                <p class="booking-location">
                    <i class="fa-solid fa-location-dot"></i>
                    <%= booking.listing.location %>, <%= booking.listing.country %>
                </p>

                <div class="booking-info-group">
                    <p><strong>Status:</strong> 
                        <span class="status-badge <%= booking.status %>">
                            <%= booking.status %>
                        </span>
                    </p>

                    <p><strong>Check-in:</strong>
                        <%= new Date(booking.checkIn).toDateString() %>
                    </p>

                    <p><strong>Check-out:</strong>
                        <%= new Date(booking.checkOut).toDateString() %>
                    </p>

                    <p><strong>Guests:</strong>
                        <%= booking.guests %>
                    </p>

                    <p class="booking-price">
                        £<%= booking.totalPrice %> total
                    </p>
                </div>

                <div class="booking-buttons">

                    <a href="/listings/<%= booking.listing._id %>" class="btn">
                        View Listing
                    </a>

                    <% if(booking.status === "pending") { %>

                        <form action="/bookings/<%= booking._id %>/cancel" method="POST">
                            <button class="btn delete-btn">
                                Cancel Booking
                            </button>
                        </form>

                    <% } %>

                </div>

            </div>

        </div>

    <% }) %>

</div>

<% } %>