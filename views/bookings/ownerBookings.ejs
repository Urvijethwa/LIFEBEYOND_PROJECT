<% layout("layouts/boilerplate") %>

<div class="page-header">
    <div>
        <h1>Host Dashboard</h1>
        <p class="location">Manage viewing requests and confirmed paid bookings separately.</p>
    </div>
</div>

<%
    const viewingRequests = bookings.filter(b =>
        b.status === "enquiry" || b.status === "approved" || b.status === "rejected"
    );

    const paidBookings = bookings.filter(b =>
        b.status === "paid"
    );
%>

<h2>Viewing Requests</h2>

<% if(viewingRequests.length === 0) { %>
    <div class="empty-state">
        <p>No viewing requests yet.</p>
    </div>
<% } else { %>
    <div class="booking-table-wrapper">
        <table class="booking-table">
            <thead>
                <tr>
                    <th>Request ID</th>
                    <th>Listing</th>
                    <th>Guest</th>
                    <th>Status</th>
                    <th>Viewing Date</th>
                    <th>Viewing Time</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                <% for(let booking of viewingRequests) { %>
                    <tr>
                        <td><strong><%= booking._id.toString().slice(-8).toUpperCase() %></strong></td>
                        <td><%= booking.listing ? booking.listing.title : "Listing unavailable" %></td>
                        <td><%= booking.user ? booking.user.username : "Unknown guest" %></td>

                        <td>
                            <% if(booking.status === "enquiry") { %>
                                <span class="status-badge pending">Viewing Request</span>
                            <% } else if(booking.status === "approved") { %>
                                <span class="status-badge approved">Approved</span>
                            <% } else if(booking.status === "rejected") { %>
                                <span class="status-badge rejected">Declined</span>
                            <% } %>
                        </td>

                        <td><%= booking.viewingDate ? booking.viewingDate.toDateString() : "-" %></td>
                        <td><%= booking.viewingTime || "-" %></td>

                        <td>
                            <% if(booking.status === "enquiry") { %>
                                <div class="table-actions">
                                    <form action="/bookings/<%= booking._id %>/approve" method="POST">
                                        <button class="btn">Approve</button>
                                    </form>

                                    <form action="/bookings/<%= booking._id %>/reject" method="POST">
                                        <button class="btn delete-btn">Decline</button>
                                    </form>
                                </div>
                            <% } else { %>
                                <span>-</span>
                            <% } %>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
<% } %>

<h2 style="margin-top: 45px;">Paid Bookings</h2>

<% if(paidBookings.length === 0) { %>
    <div class="empty-state">
        <p>No paid bookings yet.</p>
    </div>
<% } else { %>
    <div class="booking-table-wrapper">
        <table class="booking-table">
            <thead>
                <tr>
                    <th>Booking ID</th>
                    <th>Listing</th>
                    <th>Guest</th>
                    <th>Status</th>
                    <th>Check-in</th>
                    <th>Check-out</th>
                    <th>Guests</th>
                    <th>Total</th>
                </tr>
            </thead>

            <tbody>
                <% for(let booking of paidBookings) { %>
                    <tr>
                        <td><strong><%= booking._id.toString().slice(-8).toUpperCase() %></strong></td>
                        <td><%= booking.listing ? booking.listing.title : "Listing unavailable" %></td>
                        <td><%= booking.user ? booking.user.username : "Unknown guest" %></td>

                        <td>
                            <span class="status-badge paid">Confirmed</span>
                        </td>

                        <td><%= booking.checkIn ? booking.checkIn.toDateString() : "-" %></td>
                        <td><%= booking.checkOut ? booking.checkOut.toDateString() : "-" %></td>
                        <td><%= booking.guests || "-" %></td>
                        <td>£<%= booking.totalPrice || 0 %></td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
<% } %>