<% layout("layouts/boilerplate") %>

<div class="page-header">
    <div>
        <h1>Booking Requests</h1>
        <p class="location">Manage enquiries and booking requests for your listings.</p>
    </div>
</div>

<% if(bookings.length === 0) { %>
    <div class="empty-state">
        <p>No booking requests yet.</p>
    </div>
<% } else { %>

    <div class="booking-table-wrapper">
        <table class="booking-table">
            <thead>
                <tr>
                    <th>Booking ID</th>
                    <th>Listing</th>
                    <th>Guest</th>
                    <th>Status</th>
                    <th>Check-in</th>
                    <th>Check-out</th>
                    <th>Guests</th>
                    <th>Total</th>
                </tr>
            </thead>

            <tbody>
                <% for(let booking of bookings) { %>
                    <tr>
                        <td>
                            <strong><%= booking._id.toString().slice(-8).toUpperCase() %></strong>
                        </td>

                        <td>
                            <%= booking.listing ? booking.listing.title : "Listing unavailable" %>
                        </td>

                        <td>
                            <%= booking.user ? booking.user.username : "Unknown guest" %>
                        </td>

                        <td>
                            <span class="status-badge <%= booking.status %>">
                                <%= booking.status %>
                            </span>
                        </td>

                        <td>
                            <%= booking.checkIn ? booking.checkIn.toDateString() : "-" %>
                        </td>

                        <td>
                            <%= booking.checkOut ? booking.checkOut.toDateString() : "-" %>
                        </td>

                        <td>
                            <%= booking.guests || "-" %>
                        </td>

                        <td>
                            £<%= booking.totalPrice || 0 %>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

<% } %>