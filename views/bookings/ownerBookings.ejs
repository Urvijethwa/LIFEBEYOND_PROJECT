<% layout("layouts/boilerplate") %>

<div class="page-header">
    <div>
        <h1>Booking Requests</h1>
        <p class="location">View enquiries and booking requests for your listings.</p>
    </div>
</div>

<% if(bookings.length === 0) { %>
    <div class="empty-state">
        <p>No booking requests yet.</p>
    </div>
<% } else { %>
    <div class="review-container">
        <% for(let booking of bookings) { %>
            <div class="review-card">
                <h3><%= booking.listing ? booking.listing.title : "Listing unavailable" %></h3>

                <% if(booking.user) { %>
                    <p><strong>Requested by:</strong> <%= booking.user.username %></p>
                <% } %>

                <p><strong>Status:</strong> <%= booking.status %></p>

                <% if(booking.message) { %>
                    <p><strong>Message:</strong> <%= booking.message %></p>
                <% } %>

                <% if(booking.checkIn && booking.checkOut) { %>
                    <p><strong>Check-in:</strong> <%= booking.checkIn.toDateString() %></p>
                    <p><strong>Check-out:</strong> <%= booking.checkOut.toDateString() %></p>
                    <p><strong>Guests:</strong> <%= booking.guests %></p>
                    <p><strong>Total:</strong> £<%= booking.totalPrice %></p>
                <% } else { %>
                    <p class="location">This is an enquiry message only. No booking dates have been selected yet.</p>
                <% } %>

                <% if(booking.status === "pending" || booking.status === "enquiry") { %>
                    <div class="action-buttons">
                        <form action="/bookings/<%= booking._id %>/approve" method="POST">
                            <button class="btn">Approve</button>
                        </form>

                        <form action="/bookings/<%= booking._id %>/reject" method="POST">
                            <button class="btn delete-btn">Reject</button>
                        </form>
                    </div>
                <% } %>
            </div>
        <% } %>
    </div>
<% } %>