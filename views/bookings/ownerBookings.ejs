<% layout("layouts/boilerplate") %>

<div class="page-header">
    <div>
        <h1>Viewing / Booking Requests</h1>
        <p class="location">Manage viewing and booking requests for your listings.</p>
    </div>
</div>

<% if(bookings.length === 0) { %>
    <div class="empty-state">
        <p>No requests yet.</p>
    </div>
<% } else { %>

    <div class="booking-table-wrapper">
        <table class="booking-table">
            <thead>
                <tr>
                    <th>Request ID</th>
                    <th>Listing</th>
                    <th>Guest</th>
                    <th>Status</th>
                    <th>Check-in</th>
                    <th>Check-out</th>
                    <th>Guests</th>
                    <th>Total</th>
                    <th>Action</th>
                    <th>Viewing Date</th>
                    <th>Viewing Time</th>
                </tr>
            </thead>

            <tbody>
                <% for(let booking of bookings) { %>
                    <tr>
                        <td>
                            <strong><%= booking._id.toString().slice(-8).toUpperCase() %></strong>
                        </td>

                        <td>
                            <%= booking.listing ? booking.listing.title : "Listing unavailable" %>
                        </td>

                        <td>
                            <%= booking.user ? booking.user.username : "Unknown guest" %>
                        </td>

                        <td>
                            <% if(booking.status === "enquiry") { %>
                                <span class="status-badge pending">Viewing Request</span>
                            <% } else if(booking.status === "approved") { %>
                                <span class="status-badge approved">Approved</span>
                            <% } else if(booking.status === "paid") { %>
                                <span class="status-badge paid">Confirmed</span>
                            <% } else if(booking.status === "rejected") { %>
                                <span class="status-badge rejected">Declined</span>
                            <% } else if(booking.status === "cancelled") { %>
                                <span class="status-badge cancelled">Cancelled</span>
                            <% } else { %>
                                <span class="status-badge pending"><%= booking.status %></span>
                            <% } %>
                        </td>

                        <td>
                            <%= booking.checkIn ? booking.checkIn.toDateString() : "-" %>
                        </td>

                        <td>
                            <%= booking.checkOut ? booking.checkOut.toDateString() : "-" %>
                        </td>

                        <td>
                            <%= booking.guests || "-" %>
                        </td>

                        <td>
                            £<%= booking.totalPrice || 0 %>
                        </td>

                        <!-- VIEWING DATE -->
                        <td>
                            <%= booking.viewingDate ? booking.viewingDate.toDateString() : "-" %>
                        </td>

                        <!-- VIEWING TIME -->
                        <td>
                            <%= booking.viewingTime || "-" %>
                        </td>

                        <!-- ACTION -->
                        <td>
                            <% if(booking.status === "enquiry" || booking.status === "pending") { %>
                                <div class="table-actions">
                                    <form action="/bookings/<%= booking._id %>/approve" method="POST">
                                        <button class="btn">Approve</button>
                                    </form>

                                    <form action="/bookings/<%= booking._id %>/reject" method="POST">
                                        <button class="btn delete-btn">Decline</button>
                                    </form>
                                </div>
                            <% } else { %>
                                <span>-</span>
                            <% } %>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

<% } %>