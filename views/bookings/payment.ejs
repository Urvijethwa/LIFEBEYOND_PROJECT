<% layout("layouts/boilerplate") %>
<!-- Using the main layout so the page keeps consistent styling (navbar, footer, etc.) -->

<h1 class="form-heading">Payment Simulation</h1>
<!-- Page title - makes it clear this is not a real payment but a simulation -->

<div class="listing-form">

    <!-- Show the listing being paid for -->
    <h2><%= booking.listing.title %></h2>

    <p class="location">
        This is a simulated payment page for your final year project.
    </p>
    <!-- Inform the user this is not a real payment system -->

    <!-- Booking details shown to the user before paying -->
    <p><strong>Check-in:</strong> <%= booking.checkIn.toDateString() %></p>
    <p><strong>Check-out:</strong> <%= booking.checkOut.toDateString() %></p>

    <p><strong>Guests:</strong> <%= booking.guests %></p>

    <!-- Total price calculated from backend -->
    <p class="price">
        <strong>Total to pay: £<%= booking.totalPrice %></strong>
    </p>

    <!-- 
        Payment form
        Sends request to backend route:
        POST /bookings/:id/pay
        This will process payment (or simulate it)
    -->
    <form action="/bookings/<%= booking._id %>/pay" method="POST">
        <button class="btn">Pay Now</button>
    </form>

    <!-- Option to go back without paying -->
    <a href="/my-bookings" class="btn secondary-btn">
        Back to My Bookings
    </a>
</div>