<nav class="navbar">
    <div class="nav-left">
        <a href="/listings" class="logo">
            LifeBeyond<span><i class="fa-solid fa-leaf"></i></span>
        </a>
    </div>

    <button class="hamburger" onclick="toggleMenu()">☰</button>

    <div class="nav-right" id="navMenu">
        <a href="/listings">Home</a>

        <% if(typeof currentUser !== "undefined" && currentUser) { %>

            <% if(currentUser.role === "host") { %>
                <a href="/listings/new">Add Listing</a>
                <a href="/listings/my/listings">My Listings</a>
                <a href="/owner/bookings">Booking Requests</a>
                <a href="/host/profile">Host Profile</a>
            <% } %>

            <% if(currentUser.role === "guest") { %>
                <a href="/wishlist">Wishlist</a>
                <a href="/my-bookings">My Bookings</a>
            <% } %>
            <% if (currentUser && currentUser.role === "admin") { %>
            <a href="/admin/dashboard">Admin</a>
            <% } %>

            <a href="/account">Account</a>
            <a href="/logout">Logout</a>

        <% } else { %>
            <a href="/register">Register</a>
            <a href="/login">Login</a>
        <% } %>
    </div>
</nav>

<script>
function toggleMenu() {
    const menu = document.getElementById("navMenu");
    if (menu) {
        menu.classList.toggle("show-menu");
    }
}
</script>