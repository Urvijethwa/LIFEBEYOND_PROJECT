<% layout("layouts/boilerplate") %>

<h1 class="form-heading">Holiday Recommender Assistant</h1>

<form action="/listings/assistant/results" method="GET" class="listing-form">
    <div class="form-group">
        <label for="budget">Maximum Budget (£)</label>
        <input type="number" name="budget" id="budget" placeholder="Enter your budget" required>
    </div>

    <div class="form-group">
        <label for="location">Preferred Location</label>
        <input type="text" name="location" id="location" placeholder="e.g. Leicester" required>
    </div>

    <div class="form-group">
        <label for="country">Country</label>
        <input type="text" name="country" id="country" placeholder="e.g. UK" required>
    </div>

    <div class="form-group">
        <label for="stayType">Stay Type</label>
        <select name="stayType" id="stayType" required>
            <option value="">Select stay type</option>
            <option value="short">Short-term</option>
            <option value="long">Long-term</option>
        </select>
    </div>

    <div class="form-group">
        <label for="guests">Number of Guests</label>
        <input type="number" name="guests" id="guests" min="1" placeholder="Enter number of guests" required>
    </div>

    <div class="form-group">
        <label for="radius">How far from your preferred location?</label>
        <select name="radius" id="radius" required>
            <option value="">Select distance</option>
            <option value="5">Very close (5 km)</option>
            <option value="10">Nearby (10 km)</option>
            <option value="25">Flexible (25 km)</option>
            <option value="50">Wide area (50 km)</option>
        </select>
    </div>

    <button type="submit" class="btn">Get Recommendations</button>
</form>