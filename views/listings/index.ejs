<% layout("layouts/boilerplate") %>
<!-- Uses the main layout (navbar, footer, styling consistency) -->

<!-- Show logged-in user -->
<% if(currentUser) { %>
    <div class="logged-user-box">
        Hello, <strong><%= currentUser.username %></strong> 
        (
        <% if(currentUser.role === "admin") { %>
            Admin
        <% } else if(currentUser.role === "host") { %>
            Host
        <% } else { %>
            Guest
        <% } %>
        )
    </div>
<% } %>

<!-- Page heading -->
<div class="page-header">
    <div>
        <h1>
    <%= currentUser && currentUser.role === "host" ? "All Listings" : "Find your stay" %>
        </h1>

        <p class="location">
            <%= currentUser && currentUser.role === "host" 
                ? "Explore stylish stays, unique locations, and travel-ready accommodation." 
                : "Search accommodation by location, price, and travel preference." 
            %>
        </p>
    </div>

    <!-- Only hosts can add listings -->
    <% if(currentUser && currentUser.role === "host") { %>
        <a href="/listings/new" class="btn">Add New Listing</a>
    <% } %>
</div>

<!-- Search + filter (only for guests or not logged in) -->
<% if(!currentUser || currentUser.role === "guest") { %>
    <form action="/listings" method="GET" class="search-form">
        <div class="search-group">

            <!-- Search by keyword -->
            <input 
            type="text" 
            name="search" 
            placeholder="Search title or description"
            value="<%= search || '' %>"
            >

            <!-- Search by location -->
            <input 
                type="text" 
                name="location" 
                placeholder="Search by location"
                value="<%= location || '' %>"
            >

            <!-- Max price filter -->
            <input 
                type="number" 
                name="maxPrice" 
                placeholder="Max price"
                value="<%= maxPrice || '' %>"
            >

            <!-- Sorting dropdown -->
            <select name="sort" class="sort-select">
                <option value="">Sort By</option>

                <option value="priceLowHigh" <%= sort === "priceLowHigh" ? "selected" : "" %>>
                    Price: Low to High
                </option>

                <option value="priceHighLow" <%= sort === "priceHighLow" ? "selected" : "" %>>
                    Price: High to Low
                </option>

                <option value="titleAZ" <%= sort === "titleAZ" ? "selected" : "" %>>
                    Title: A to Z
                </option>
            </select>

            <!-- Submit -->
            <button type="submit" class="btn">Search</button>

            <!-- Reset filters -->
            <a href="/listings" class="btn secondary-btn">Reset</a>
        </div>
    </form>
    <div class="search-tip">
    <i class="fa-solid fa-circle-info"></i>
    Search using any single field or combine multiple filters.
</div>
<% } %>

<!-- Show message if filters are used -->
<% if(search || location || maxPrice) { %>
    <p class="filter-info">Showing filtered results</p>
<% } %>

<!-- Listings grid -->
<div class="card-container">

    <% for(let listing of listings) { %>
        <!-- Clickable card -->
        <a href="/listings/<%= listing._id %>" class="listing-link">

            <div class="card">

        <div class="card-image-wrap">
            <img 
                src="<%= listing.image %>" 
                alt="<%= listing.title %>" 
                class="card-img"
                onerror="this.src='https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?w=1000'"
            >

            <div class="card-badge">Available</div>
        </div>

        <div class="card-body">

            <div class="card-title-row">
                <h3><%= listing.title %></h3>

                <% 
                    let averageRating = 0;
                    if (listing.reviews.length > 0) {
                        const total = listing.reviews.reduce((sum, review) => sum + review.rating, 0);
                        averageRating = (total / listing.reviews.length).toFixed(1);
                    }
                %>

                <% if(listing.reviews.length > 0) { %>
                    <span class="mini-rating">⭐ <%= averageRating %></span>
                <% } else { %>
                    <span class="mini-rating">New</span>
                <% } %>
            </div>

            <p class="card-location">
                <i class="fa-solid fa-location-dot"></i>
                <%= listing.location %>, <%= listing.country %>
            </p>

            <p class="guest-info">
                Up to <%= listing.maxGuests || 1 %> guest<%= (listing.maxGuests || 1) > 1 ? "s" : "" %>
            </p>

            <div class="card-bottom">
                <p class="price"><strong>£<%= listing.price %></strong> / night</p>
                <span class="view-btn">View Details</span>
            </div>

        </div>
    </div>
        </a>
    <% } %>

</div>

<% if(listings.length === 0) { %>
    <p>No listings found. Try adjusting your search filters.</p>
<% } %>