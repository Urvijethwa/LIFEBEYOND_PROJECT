<% layout("layouts/boilerplate") %>

<div class="page-header">
    <h1>My Listings</h1>
    <p class="location">Manage the properties you have created as a host.</p>
    <a href="/listings/new" class="btn">Add New Listing</a>
</div>

<% if(listings.length === 0) { %>
    <div class="empty-state">
        <p>You have not created any listings yet.</p>
        <a href="/listings/new" class="btn" style="margin-top:18px;">Create Listing</a>
    </div>
<% } else { %>

<div class="host-listings-grid">
    <% for(let listing of listings) { %>

        <% 
            let averageRating = 0;
            if (listing.reviews.length > 0) {
                const total = listing.reviews.reduce((sum, review) => sum + review.rating, 0);
                averageRating = (total / listing.reviews.length).toFixed(1);
            }
        %>

        <div class="host-listing-card">
            <img 
                src="<%= listing.image %>" 
                alt="<%= listing.title %>"
                onerror="this.src='https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?w=1000'"
            >

            <div class="host-listing-body">
                <h3><%= listing.title %></h3>

                <p class="location">
                    <i class="fa-solid fa-location-dot"></i>
                    <%= listing.location %>, <%= listing.country %>
                </p>

                <p>
                    <% if(listing.reviews.length > 0) { %>
                        ⭐ <strong><%= averageRating %></strong> / 5
                    <% } else { %>
                        New listing
                    <% } %>
                </p>

                <p class="price">£<%= listing.price %> / night</p>

                <div class="host-listing-actions">
                    <a href="/listings/<%= listing._id %>" class="btn">View</a>
                    <a href="/listings/<%= listing._id %>/edit" class="btn secondary-btn">Edit</a>
                </div>
            </div>
        </div>

    <% } %>
</div>

<% } %>