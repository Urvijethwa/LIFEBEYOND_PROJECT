<% layout("layouts/boilerplate") %>
<!-- Uses main layout (navbar, footer, consistent UI styling) -->

<h1 class="form-heading">Add New Listing</h1>
<!-- Page title for creating a new property -->

<form action="/listings" method="POST" class="listing-form">
    <!-- Form sends data to backend route POST /listings -->

    <!-- Title input -->
    <div class="form-group">
        <label for="title">Title</label>
        <input 
            name="title" 
            id="title" 
            placeholder="Enter title" 
            required
        >
        <!-- Required field to enter listing name -->
    </div>

    <!-- Description input -->
    <div class="form-group">
        <label for="description">Description</label>
        <textarea 
            name="description" 
            id="description" 
            placeholder="Enter description" 
            required
        ></textarea>
        <!-- Required field for listing details -->
    </div>

    <!-- Image URL input -->
    <div class="form-group">
        <label for="image">Image URL</label>
        <input 
            name="image" 
            id="image" 
            placeholder="Enter image URL"
        >
        <!-- Optional: if empty, default image will be used -->
    </div>

    <!-- Price input -->
    <div class="form-group">
        <label for="price">Price</label>
        <input 
            name="price" 
            id="price" 
            type="number" 
            placeholder="Enter price" 
            required
        >
        <!-- Required numeric input for price per night -->
    </div>

    <!-- Location input -->
    <div class="form-group">
        <label for="location">Location</label>
        <input 
            name="location" 
            id="location" 
            placeholder="Enter location" 
            required
        >
        <!-- Required: used for search + geocoding -->
    </div>

    <!-- Country input -->
    <div class="form-group">
        <label for="country">Country</label>
        <input 
            name="country" 
            id="country" 
            placeholder="Enter country" 
            required
        >
        <!-- Required: helps filtering and AI recommendations -->
    </div>

    <!-- Submit button -->
    <button type="submit" class="btn">Add Listing</button>
    <!-- Sends all form data to backend -->
</form>