<% layout("layouts/boilerplate") %>

<div class="show-container">
    <img 
        src="<%= listing.image %>" 
        alt="<%= listing.title %>" 
        class="show-img"
        onerror="this.src='https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?w=1000'"
    >

    <h1><%= listing.title %></h1>

    <% if(listing.reviews.length > 0) { %>
        <p class="rating-summary">⭐ <strong><%= averageRating %></strong> / 5 
        (<%= listing.reviews.length %> review<%= listing.reviews.length > 1 ? "s" : "" %>)</p>
    <% } else { %>
        <p class="rating-summary">No ratings yet</p>
    <% } %>

    <p><%= listing.description %></p>
    <p class="price"><strong>£<%= listing.price %></strong></p>
    <p class="location"><%= listing.location %>, <%= listing.country %></p>

    <% if(listing.owner) { %>
        <p class="location">Created by: <%= listing.owner.username %></p>
    <% } %>

    <div class="action-buttons">
        <a href="/listings" class="btn secondary-btn">Back</a>

        <% if(currentUser) { %>
            <% if(isSaved) { %>
                <form action="/listings/<%= listing._id %>/remove-wishlist" method="POST">
                    <button class="btn secondary-btn">Remove from Wishlist</button>
                </form>
            <% } else { %>
                <form action="/listings/<%= listing._id %>/wishlist" method="POST">
                    <button class="btn">Add to Wishlist</button>
                </form>
            <% } %>
        <% } %>

        <% if(currentUser && listing.owner && currentUser.toString() === listing.owner._id.toString()) { %>
            <a href="/listings/<%= listing._id %>/edit" class="btn">Edit</a>

            <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
                <button class="btn delete-btn">Delete</button>
            </form>
        <% } %>
    </div>

    <hr style="margin: 30px 0;">
    <% if(listing.latitude != null && listing.longitude != null) { %>
        <div class="map-section">
            <h2>Location on Map</h2>
            <div 
                id="map"
                data-lat="<%= listing.latitude %>"
                data-lng="<%= listing.longitude %>"
                data-title="<%= listing.title %>"
            ></div>
        </div>
    
        <script>
            window.addEventListener("load", function () {
                const mapElement = document.getElementById("map");
                const lat = parseFloat(mapElement.dataset.lat);
                const lng = parseFloat(mapElement.dataset.lng);
                const title = mapElement.dataset.title;
    
                const map = L.map("map").setView([lat, lng], 13);
    
                L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
                    attribution: "&copy; OpenStreetMap contributors"
                }).addTo(map);
    
                L.marker([lat, lng])
                    .addTo(map)
                    .bindPopup(title)
                    .openPopup();
            });
        </script>
    <% } %>

    <% if(nearbyListings && nearbyListings.length > 0) { %>
        <hr style="margin: 30px 0;">
    
        <h2>Nearby Listings</h2>
    
        <div class="card-container">
            <% for(let nearby of nearbyListings) { %>
                <a href="/listings/<%= nearby._id %>" class="listing-link">
                    <div class="card">
                        <img 
                            src="<%= nearby.image %>" 
                            alt="<%= nearby.title %>" 
                            class="card-img"
                            onerror="this.src='https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?w=1000'"
                        >
                        <div class="card-body">
                            <h3><%= nearby.title %></h3>
                            <p><%= nearby.description %></p>
                            <p class="price">£<%= nearby.price %></p>
                            <p class="location"><%= nearby.location %>, <%= nearby.country %></p>
                            <p class="card-rating"><strong><%= nearby.distance %> km away</strong></p>
                        </div>
                    </div>
                </a>
            <% } %>
        </div>
    <% } %>

    <h2>Reviews</h2>

    <% if(currentUser) { %>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" class="listing-form">
            <div class="form-group">
                <label for="rating">Rating</label>
                <select name="rating" id="rating" required>
                    <option value="">Select rating</option>
                    <option value="1">1 - Poor</option>
                    <option value="2">2 - Fair</option>
                    <option value="3">3 - Good</option>
                    <option value="4">4 - Very Good</option>
                    <option value="5">5 - Excellent</option>
                </select>
            </div>

            <div class="form-group">
                <label for="comment">Comment</label>
                <textarea name="comment" id="comment" required></textarea>
            </div>

            <button class="btn">Add Review</button>
        </form>
    <% } %>

    <div class="review-container">
        <% for(let review of listing.reviews) { %>
            <div class="review-card">
                <p><strong>Rating:</strong> 
                    <% for(let i = 1; i <= 5; i++) { %>
                        <% if(i <= review.rating) { %>
                            ⭐
                        <% } else { %>
                            ☆
                        <% } %>
                    <% } %>
                </p>
                <p><%= review.comment %></p>

                <% if(review.author) { %>
                    <p class="location">By: <%= review.author.username %></p>
                <% } %>

                <% if(currentUser && review.author && currentUser.toString() === review.author._id.toString()) { %>
                    <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                        <button class="btn delete-btn">Delete Review</button>
                    </form>
                <% } %>
            </div>
        <% } %>
    </div>

    <% if(listing.reviews.length === 0) { %>
        <p>No reviews yet.</p>
    <% } %>
</div>