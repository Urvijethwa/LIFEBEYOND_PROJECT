<% layout("layouts/boilerplate") %>

<div class="listing-show-page">

    <a href="/listings" class="back-link">
        <i class="fa-solid fa-arrow-left"></i> Back to listings
    </a>

    <!-- HEADER -->
    <div class="show-header">
        <div>
            <h1><%= listing.title %></h1>

            <div class="show-meta">
                <% if(listing.reviews.length > 0) { %>
                    <span>⭐ <strong><%= averageRating %></strong> · <%= listing.reviews.length %> review<%= listing.reviews.length > 1 ? "s" : "" %></span>
                <% } else { %>
                    <span>New listing</span>
                <% } %>

                <span>
                    <i class="fa-solid fa-location-dot"></i>
                    <%= listing.location %>, <%= listing.country %>
                </span>
            </div>
        </div>
    </div>

    <!-- HERO IMAGE -->
    <div class="show-hero">
        <img 
            src="<%= listing.image %>" 
            alt="<%= listing.title %>"
            onerror="this.src='https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?w=1000'"
        >
    </div>

    <!-- MAIN CONTENT -->
    <div class="show-grid">

        <!-- LEFT CONTENT -->
        <div class="show-main">

            <section class="show-section">
                <h2>About this stay</h2>
                <p class="show-description"><%= listing.description %></p>
            </section>

            <section class="show-section">
                <h2>Property highlights</h2>

                <div class="highlight-grid">
                    <div class="highlight-card">
                        <i class="fa-solid fa-users"></i>
                        <div>
                            <strong>Guest capacity</strong>
                            <p>Up to <%= listing.maxGuests || 1 %> guest<%= (listing.maxGuests || 1) > 1 ? "s" : "" %></p>
                        </div>
                    </div>

                    <div class="highlight-card">
                        <i class="fa-solid fa-map-location-dot"></i>
                        <div>
                            <strong>Location based</strong>
                            <p>Map and nearby listings available</p>
                        </div>
                    </div>

                    <div class="highlight-card">
                        <i class="fa-solid fa-star"></i>
                        <div>
                            <strong>Guest feedback</strong>
                            <p><%= listing.reviews.length %> review<%= listing.reviews.length !== 1 ? "s" : "" %></p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- HOST SECTION -->
            <% if(listing.owner) { %>
                <section class="show-section">
                    <h2>Meet your host</h2>

                    <div class="modern-host-card">
                        <div class="modern-host-left">
                            <div class="host-avatar">
                                <%= listing.owner.username.charAt(0).toUpperCase() %>
                            </div>
                            <h3><%= listing.owner.username %></h3>
                            <p>Verified Host</p>
                        </div>

                        <div class="modern-host-right">
                            <p><strong>Work:</strong> <%= listing.owner.hostWork || "Not specified" %></p>
                            <p><strong>Lives in:</strong> <%= listing.owner.hostLocation || "Location not added" %></p>
                            <p><strong>Response:</strong> <%= listing.owner.responseTime || "Usually responds within 24 hours" %></p>
                            <p><strong>About:</strong> <%= listing.owner.bio || "This host has not added a bio yet." %></p>

                            <% if(currentUser && listing.owner && String(currentUser._id) !== String(listing.owner._id)) { %>
                                <a href="/messages/new/<%= listing._id %>" class="btn secondary-btn host-message-btn">
                                    Message Host
                                </a>
                            <% } %>
                        </div>
                    </div>
                </section>
            <% } %>

            <!-- MAP -->
            <% if(listing.latitude != null && listing.longitude != null) { %>
                <section class="show-section">
                    <h2>Location on map</h2>

                    <div 
                        id="map"
                        data-lat="<%= listing.latitude %>"
                        data-lng="<%= listing.longitude %>"
                        data-title="<%= listing.title %>"
                    ></div>
                </section>

                <script>
                    window.addEventListener("load", function () {
                        const mapElement = document.getElementById("map");

                        if (!mapElement) return;

                        const lat = parseFloat(mapElement.dataset.lat);
                        const lng = parseFloat(mapElement.dataset.lng);
                        const title = mapElement.dataset.title;

                        const map = L.map("map").setView([lat, lng], 13);

                        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png").addTo(map);

                        L.marker([lat, lng])
                            .addTo(map)
                            .bindPopup(title)
                            .openPopup();
                    });
                </script>
            <% } %>

            <!-- NEARBY LISTINGS -->
            <% if(nearbyListings && nearbyListings.length > 0) { %>
                <section class="show-section">
                    <h2>Nearby listings</h2>

                    <div class="nearby-grid">
                        <% for(let nearby of nearbyListings) { %>
                            <a href="/listings/<%= nearby._id %>" class="nearby-card">
                                <img src="<%= nearby.image %>" alt="<%= nearby.title %>">
                                <div>
                                    <h3><%= nearby.title %></h3>
                                    <p><%= nearby.location %>, <%= nearby.country %></p>
                                    <strong>£<%= nearby.price %> / night</strong>
                                    <span><%= nearby.distance.toFixed(1) %> km away</span>
                                </div>
                            </a>
                        <% } %>
                    </div>
                </section>
            <% } %>

            <!-- REVIEWS -->
            <section class="show-section" id="reviews">
                <h2>Reviews</h2>

                <% if(canReview) { %>
                    <form action="/listings/<%= listing._id %>/reviews" method="POST" class="listing-form compact-review-form">
                        <div class="form-group">
                            <label>Rating</label>
                            <select name="rating" required>
                                <option value="">Select rating</option>
                                <option value="1">1 - Poor</option>
                                <option value="2">2 - Fair</option>
                                <option value="3">3 - Good</option>
                                <option value="4">4 - Very Good</option>
                                <option value="5">5 - Excellent</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Comment</label>
                            <textarea name="comment" required></textarea>
                        </div>

                        <button class="btn">Add Review</button>
                    </form>
                <% } else if(currentUser) { %>
                    <p class="muted-text">You can leave a review after completing a paid booking.</p>
                <% } else { %>
                    <p class="muted-text">Login to book and review this property.</p>
                <% } %>

                <% if(listing.reviews.length === 0) { %>
                    <p class="muted-text">No reviews yet.</p>
                <% } %>

                <div class="modern-review-grid">
                    <% for(let review of listing.reviews) { %>
                        <div class="modern-review-card">
                            <p class="review-stars">
                                <% for(let i = 1; i <= 5; i++) { %>
                                    <%= i <= review.rating ? "⭐" : "☆" %>
                                <% } %>
                            </p>

                            <p><%= review.comment %></p>

                            <% if(review.author) { %>
                                <small>By <%= review.author.username %></small>
                            <% } %>

                            <% if(currentUser && review.author && String(currentUser._id) !== String(listing.owner._id)) { %>
                                <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                                    <button class="btn delete-btn small-btn">Delete</button>
                                </form>
                            <% } %>
                        </div>
                    <% } %>
                </div>
            </section>

        </div>

        <!-- RIGHT BOOKING CARD -->
        <aside class="booking-card">
            <div class="booking-price">
                <strong>£<%= listing.price %></strong>
                <span>/ night</span>
            </div>

            <% if(listing.reviews.length > 0) { %>
                <p class="booking-rating">⭐ <%= averageRating %> · <%= listing.reviews.length %> review<%= listing.reviews.length > 1 ? "s" : "" %></p>
            <% } else { %>
                <p class="booking-rating">New listing</p>
            <% } %>

            <p class="booking-location">
                <i class="fa-solid fa-location-dot"></i>
                <%= listing.location %>, <%= listing.country %>
            </p>

            <div class="booking-actions">

    <% const isOwner = currentUser && listing.owner && String(currentUser._id) === String(listing.owner._id); %>
    <% const isGuest = currentUser && currentUser.role === "guest"; %>

    <% if(!currentUser) { %>
        <a href="/login" class="btn full-btn">Login to book</a>
    <% } %>

    <% if(isGuest && !isOwner) { %>
        <a href="/listings/<%= listing._id %>/book" class="btn full-btn">Book Now</a>
        <a href="/listings/<%= listing._id %>/enquiry" class="btn secondary-btn full-btn">Book Viewing</a>

        <% if(isSaved) { %>
            <form action="/listings/<%= listing._id %>/remove-wishlist" method="POST">
                <button class="wishlist-wide active" type="submit">
                    <i class="fa-solid fa-heart"></i> Saved
                </button>
            </form>
        <% } else { %>
            <form action="/listings/<%= listing._id %>/wishlist" method="POST">
                <button class="wishlist-wide" type="submit">
                    <i class="fa-regular fa-heart"></i> Save to Wishlist
                </button>
            </form>
        <% } %>
    <% } %>

    <% if(isOwner) { %>
        <a href="/listings/<%= listing._id %>/edit" class="btn full-btn">Edit Listing</a>

        <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
            <button class="btn delete-btn full-btn">Delete Listing</button>
        </form>
    <% } %>

</div>
</div>