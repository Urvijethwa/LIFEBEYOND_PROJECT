<% layout("layouts/boilerplate") %>

<div class="page-header">
    <div>
        <h1>My Wishlist</h1>
        <p class="location">Your saved stays are stored here for quick access.</p>
    </div>
</div>

<% if(wishlist.length === 0) { %>
    <div class="empty-state">
        <p>You have no saved listings yet.</p>
        <a href="/listings" class="btn" style="margin-top: 18px;">Explore Stays</a>
    </div>
<% } else { %>

    <div class="wishlist-grid">
        <% for(let listing of wishlist) { %>
            <div class="wishlist-card">

                <a href="/listings/<%= listing._id %>" class="wishlist-image-link">
                    <img 
                        src="<%= listing.image %>" 
                        alt="<%= listing.title %>" 
                        onerror="this.src='https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?w=1000'"
                    >
                </a>

                <div class="wishlist-content">
                    <h3><%= listing.title %></h3>

                    <p class="wishlist-location">
                        <i class="fa-solid fa-location-dot"></i>
                        <%= listing.location %>, <%= listing.country %>
                    </p>

                    <p class="wishlist-price">£<%= listing.price %> / night</p>

                    <div class="wishlist-actions">
                        <a href="/listings/<%= listing._id %>" class="btn">View Details</a>

                        <form action="/listings/<%= listing._id %>/remove-wishlist" method="POST">
                            <button type="submit" class="btn delete-btn">Remove</button>
                        </form>
                    </div>
                </div>

            </div>
        <% } %>
    </div>

<% } %>