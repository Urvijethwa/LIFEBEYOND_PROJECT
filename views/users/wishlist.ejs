<% layout("layouts/boilerplate") %>
<!-- Uses main layout -->

<div class="page-header">
    <div>
        <h1>My Wishlist</h1>
        <p class="location">Save your favourite stays and come back to them anytime.</p>
    </div>
</div>

<!-- If no saved listings -->
<% if(wishlist.length === 0) { %>
    <div class="empty-state">
        <p>You have no saved listings yet.</p>
    </div>

<% } else { %>

    <!-- Show saved listings -->
    <div class="card-container">
        <% for(let listing of wishlist) { %>

            <!-- Each listing card -->
            <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="card">

                    <!-- Image with fallback -->
                    <img 
                        src="<%= listing.image %>" 
                        alt="<%= listing.title %>" 
                        class="card-img"
                        onerror="this.src='https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?w=1000'"
                    >

                    <div class="card-body">
                        <h3><%= listing.title %></h3>
                        <p><%= listing.description %></p>
                        <p class="price">£<%= listing.price %></p>
                        <p class="location"><%= listing.location %>, <%= listing.country %></p>
                    </div>

                </div>
            </a>

        <% } %>
    </div>

<% } %>